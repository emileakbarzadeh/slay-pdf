{
  "name": "slay-pdf",
  "private": true,
  "version": "0.1.0",
  "description": "Free local PDF editor and Adobe Acrobat alternative for splitting, merging, signing, posterising, resizing and editing PDFs in the browser.",
  "homepage": "https://slaypdf.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/emileakbarzadeh/slay-pdf.git"
  },
  "keywords": [
    "pdf",
    "pdf-editor",
    "local-pdf-editor",
    "free-pdf-editor",
    "adobe-acrobat-alternative",
    "merge-pdf",
    "split-pdf",
    "sign-pdf",
    "posterise-pdf",
    "delete-pdf-pages",
    "resize-pdf",
    "crop-pdf",
    "redact-pdf",
    "compress-pdf",
    "ocr-pdf",
    "pdf-to-images",
    "extract-pdf-text",
    "rotate-pdf",
    "annotate-pdf",
    "watermark-pdf",
    "add-page-numbers-to-pdf",
    "fill-pdf-forms",
    "password-protect-pdf",
    "browser-pdf-editor",
    "online-pdf-editor",
    "combine-pdf-files",
    "remove-pages-from-pdf",
    "extract-pages-from-pdf",
    "searchable-pdf",
    "pdf-redaction-tool",
    "no-upload-pdf-editor",
    "images-to-pdf",
    "jpg-to-pdf",
    "png-to-pdf",
    "edit-scanned-pdf",
    "flatten-pdf",
    "printable-poster-pdf",
    "free-adobe-pdf-editor-alternative",
    "acrobat-online-alternative",
    "adobe-pdf-merge-alternative",
    "adobe-compress-pdf-alternative",
    "adobe-fill-and-sign-alternative",
    "adobe-pdf-organizer-alternative",
    "free-pdf-editor-no-signup",
    "pdf-editor-no-watermark",
    "secure-pdf-editor",
    "pdf-editor-for-mac",
    "pdf-editor-for-windows",
    "pdf-editor-for-chromebook"
  ],
  "type": "module",
  "license": "AGPL-3.0-only",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "seo:generate": "node scripts/generate-seo.mjs",
    "seo:index": "node scripts/generate-page-index.mjs",
    "seo:feed": "node scripts/generate-discovery-feed.mjs",
    "seo:feed:json": "node scripts/generate-json-feed.mjs",
    "seo:llms": "node scripts/generate-llms.mjs",
    "seo:social": "node scripts/sync-static-social-meta.mjs",
    "seo:schema": "node scripts/sync-static-webpage-schema.mjs",
    "seo:howto": "node scripts/sync-static-howto-schema.mjs",
    "seo:entities": "node scripts/sync-static-entity-schema.mjs",
    "seo:check": "node scripts/verify-seo.mjs",
    "seo:check:live": "node scripts/verify-seo.mjs --live",
    "check": "npm run seo:check && npm run test && npm run build",
    "indexnow:submit": "node scripts/submit-indexnow.mjs"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@neslinesli93/qpdf-wasm": "^0.3.0",
    "@okathira/ghostpdl-wasm": "^1.1.0",
    "@tesseract.js-data/eng": "^1.0.0",
    "dexie": "^4.2.1",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^5.4.530",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tesseract.js": "^7.0.0",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^27.2.0",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.15"
  }
}
